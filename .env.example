# AgentBlox dev stack (Linux containers — required on Windows for Dynamic Broadcaster).
# Manual test: copy .env.example → .env, fill values, then:
#   npm run docker:up       # build + start in background
#   open http://localhost:5173
#   curl http://localhost:3001/api/health
#   npm run docker:logs     # tail server + web logs
#   npm run docker:down     # stop
#
# Required for a working demo:
#   VITE_DYNAMIC_ENVIRONMENT_ID  — Dynamic widget (browser)
#   TREASURY_ADDRESS             — AccountBlox clone on Sepolia (server / Copilot tools)
#
# Optional:
#   ENS_NAME, OPENAI_API_KEY, custom RPC URLs, LIFI_EXECUTION_SELECTOR
#
# Server-only secrets (Phase 2+) — never prefix with VITE_
#   DYNAMIC_WALLET_PASSWORD — required for docker:ops:create-wallet (Dynamic backUpToDynamic)

# --- Required: client (Vite exposes VITE_* to the browser only) ---

VITE_DYNAMIC_ENVIRONMENT_ID=

# --- Required: server (treasury ops via /api/chat) ---

TREASURY_ADDRESS=

# --- Optional: server ---

# Default treasury ENS for /ens (mainnet resolver). Leave empty until you own a name.
# Example placeholder (not registered — for docs only):
# ENS_NAME=treasury.acme.eth
ENS_NAME=

# Sepolia + mainnet RPC (defaults work for local dev)
# SEPOLIA_RPC_URL=https://rpc.sepolia.org
# MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# AgentBlox server port (Vite proxies /api → this port)
# PORT=3001

# Natural language Copilot (omit for slash-command fallback only)
# OPENAI_API_KEY=
# LLM_MODEL=gpt-4o-mini

# LI.FI integrator label for server-side compose (default: AgentBlox)
# LIFI_INTEGRATOR=AgentBlox

# LI.FI Composer API key — optional; higher rate limits (portal.li.fi / Support)
# LIFI_API_KEY=

# Composer API base URL (hackathon default)
# LIFI_COMPOSER_BASE_URL=https://ethglobal-composer.li.quest

# Sepolia token overrides (defaults: Circle USDC + Uniswap WETH)
# SEPOLIA_USDC=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
# SEPOLIA_WETH=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14

# LI.FI Composer execute selector (4 bytes) — auto-filled from compose; set for whitelist reads
# LIFI_EXECUTION_SELECTOR=0x........ 

# --- Phase 2+: Dynamic Broadcaster (server only) ---

# DYNAMIC_API_TOKEN=              # Developer → API (WaaS Authenticate + Environment Users Read/Write)
# Password for Dynamic server wallet backup — required for npm run docker:ops:create-wallet
DYNAMIC_WALLET_PASSWORD=
# BROADCASTER_WALLET_ADDRESS=0x... # NOT BROADCASTER_WALLET_ID — from data/dynamic-server-wallet.json
# Server reads VITE_DYNAMIC_ENVIRONMENT_ID from .env via dotenv — no duplicate needed.

# ANALYST role — B-fast sign + B-timelock executeWithTimeLock request (Lane B)
# Must derive to ANALYST_WALLET_ADDRESS (default 0xbC9A7dc5f68a8F3629DC8D2a4D2605e2371a5700)
# ANALYST_PRIVATE_KEY=
# ANALYST_WALLET_ADDRESS=0xbC9A7dc5f68a8F3629DC8D2a4D2605e2371a5700

# APPROVER role — B-timelock approve meta-tx sign only (SIGN_META_APPROVE)
# APPROVER_PRIVATE_KEY=
# APPROVER_WALLET_ADDRESS=0x...

# PAYMENT_INSTANT_MAX_USDC=10000000  # 10 USDC — below = B-fast, at/above = B-timelock

# --- Future: Lane A / LI.FI (Phase 4) ---
# AGENT_POLICY_PRIVATE_KEY=

# External execution target for rebalance meta-tx (Phase 4: LI.FI compose fills calldata)
# REBALANCE_EXECUTION_TARGET=0x...
# REBALANCE_EXECUTION_SELECTOR=0x........  # falls back to LIFI_EXECUTION_SELECTOR
# REBALANCE_EXECUTION_PARAMS=0x
# REBALANCE_OPERATION_TYPE=0x...  # optional; defaults to keccak256(flowId)
