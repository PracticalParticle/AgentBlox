# Vite — prefix with VITE_ for client-side access
VITE_DYNAMIC_ENVIRONMENT_ID=
VITE_SEPOLIA_RPC_URL=https://rpc.sepolia.org
VITE_LIFI_INTEGRATOR=AgentBlox

# Treasury (set after provisioning on bloxchain.app)
VITE_TREASURY_ADDRESS=
VITE_ENS_NAME=

# Server
PORT=3001
SEPOLIA_RPC_URL=https://rpc.sepolia.org
MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# Treasury — server reads these (required for Copilot tools)
TREASURY_ADDRESS=
ENS_NAME=

# Copilot LLM (optional — without key, slash-command fallback is used)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Dynamic server wallet + agent signing (Phase 2+)
DYNAMIC_API_TOKEN=
DYNAMIC_ENVIRONMENT_ID=
AGENT_POLICY_PRIVATE_KEY=
BROADCASTER_WALLET_ID=
